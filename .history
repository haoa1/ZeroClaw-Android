    "tool_call_id": "call_00_P6gH6RBm4OzjEE9AB5wjnpab",
    "content": "[package]\nname = \"zeroclaw-ffi\"\nversion = \"0.0.37\"\nedition.workspace = true\nlicense.workspace = true\ndescription = \"UniFFI-annotated facade for ZeroClaw Android bindings\"\n\n[lib]\ncrate-type = [\"cdylib\"]\nname = \"zeroclaw\"\n\n[lints]\nworkspace = true\n\n[dependencies]\nuniffi = \"0.29\"\nthiserror = \"2.0\"\n# default-features = false: The FFI layer communicates via the gateway\n# REST API, so no optional upstream features are needed (channel-matrix,\n# channel-lark, memory-postgres, observability-otel, hardware, browser-native,\n# sandbox-*, probe, rag-pdf, whatsapp-web are all excluded). The daemon\n# binary enables platform-specific features independently.\nzeroclaw = { path = \"../../zeroclaw\", default-features = false }\ntokio = { version = \"1.42\", features = [\"rt-multi-thread\", \"sync\", \"macros\"] }\ntokio-util = { version = \"0.7\", features = [\"rt\"] }\nserde = { version = \"1.0\", features = [\"derive\"] }\nserde_json = \"1.0\"\nreqwest = { version = \"0.12\", default-features = false, features = [\"json\", \"rustls-tls\", \"stream\"] }\nnanohtml2text = \"0.1\"\nfutures-util = \"0.3\"\nanyhow = \"1.0\"\nasync-trait = \"0.1\"\ntoml = \"0.8\"\ntracing = \"0.1\"\ntracing-log = { version = \"0.2\", default-features = false }\nlog = \"0.4\"\nandroid_logger = { version = \"0.13\", default-features = false }\nchrono = \"0.4\"\nrhai = { version = \"1.21\", features = [\"sync\"] }\n"
  },
